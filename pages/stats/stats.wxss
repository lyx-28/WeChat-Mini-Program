.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.stats-header {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  padding: 60rpx 32rpx 40rpx;
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.overview-section {
  padding: 0 20rpx;
  margin-top: -30rpx;
}

.overview-card {
  background: white;
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.overview-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #4CAF50;
}

.overview-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.overview-divider {
  width: 2rpx;
  height: 60rpx;
  background: #e0e0e0;
}

.chart-section {
  padding: 24rpx 20rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.week-chart {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 320rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.chart-bar {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 60rpx;
}

.bar-wrapper {
  width: 40rpx;
  height: 200rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.bar-fill {
  width: 100%;
  background: linear-gradient(180deg, #4CAF50, #66BB6A);
  border-radius: 20rpx;
  transition: height 0.3s ease;
}

.bar-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
}

.bar-value {
  font-size: 20rpx;
  color: #666;
  margin-top: 4rpx;
}

.detail-section {
  padding: 0 20rpx;
}

.detail-card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 28rpx;
  color: #666;
}

.detail-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #4CAF50;
}