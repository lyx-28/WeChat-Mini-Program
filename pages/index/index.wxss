.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.header {
  padding: 20rpx;
}

.stats-card {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: white;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

.today-section {
  padding: 0 20rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-date, .section-count {
  font-size: 24rpx;
  color: #999;
}

.today-card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.today-card.checked {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.checked-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.checked-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #4CAF50;
  margin-bottom: 12rpx;
}

.checked-content {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.checked-time {
  font-size: 24rpx;
  color: #999;
}

.checkin-form {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
}

.form-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.form-input {
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.form-textarea {
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  min-height: 120rpx;
}

.image-upload {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fafafa;
  overflow: hidden;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
}

.upload-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.upload-text {
  font-size: 24rpx;
}

.image-delete {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.6);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  line-height: 1;
}

.checked-image {
  width: 300rpx;
  height: 200rpx;
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.item-thumb {
  width: 60rpx;
  height: 60rpx;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.checkin-btn {
  margin-top: 12rpx;
}

.history-section {
  padding: 0 20rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.item-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 120rpx;
}

.item-date {
  font-size: 32rpx;
  font-weight: 600;
  color: #4CAF50;
}

.item-weekday {
  font-size: 22rpx;
  color: #999;
}

.item-center {
  flex: 1;
  padding: 0 20rpx;
}

.item-content {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.item-notes {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 400rpx;
}

.item-right {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.item-duration {
  font-size: 28rpx;
  font-weight: 600;
  color: #4CAF50;
}

.item-arrow {
  font-size: 32rpx;
  color: #ccc;
  margin-top: 8rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  background: white;
  border-radius: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #999;
}