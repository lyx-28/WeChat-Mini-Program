<view class="container">
  <view class="header">
    <text class="title">排行榜</text>
    <text class="subtitle">最高分记录</text>
  </view>

  <view class="ranking-list">
    <view wx:for="{{ rankings }}" wx:key="index" class="ranking-item" bindtap="showDetail">
      <view class="rank-badge {{ item.rank <= 3 ? 'top' : '' }}">
        <text>{{ item.rank }}</text>
      </view>
      <view class="rank-info">
        <text class="rank-score">{{ item.score }}</text>
        <text class="rank-date">{{ item.date }}</text>
      </view>
      <view class="rank-medal" wx:if="{{ item.rank <= 3 }}">
        <text>{{ medals[item.rank - 1] }}</text>
      </view>
    </view>

    <view wx:if="{{ rankings.length === 0 }}" class="empty-state">
      <text class="empty-icon">🏆</text>
      <text class="empty-text">暂无记录</text>
      <text class="empty-hint">快去游戏创造记录吧！</text>
    </view>
  </view>

  <button class="back-btn" bindtap="goBack">返回游戏</button>
</view>