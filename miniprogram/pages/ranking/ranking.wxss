page {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  min-height: 100%;
}

.container {
  width: 100%;
  min-height: 100vh;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
  padding-bottom: 160rpx;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

.ranking-list {
  width: 100%;
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.rank-badge {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.rank-badge.top {
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
}

.rank-badge text {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

.rank-info {
  flex: 1;
}

.rank-score {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #fbbf24;
}

.rank-date {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 4rpx;
}

.rank-medal {
  font-size: 40rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 10rpx;
}

.empty-hint {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

.back-btn {
  position: fixed;
  bottom: 60rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 360rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  background: linear-gradient(90deg, #667eea, #764ba2);
  color: #fff;
  border: none;
}